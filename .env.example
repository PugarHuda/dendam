# ─────────────────────────────────────────────────────────────
# Dendam — environment variables
# Copy to `.env.local` and fill in. Without MemWal vars set, the app
# falls back to a LOCAL file-based memory store (great for dev, NOT for
# the hackathon submission — submission memory must live on Walrus Mainnet).
# ─────────────────────────────────────────────────────────────

# --- LLM (pilih SALAH SATU: Anthropic langsung ATAU OpenRouter) ---
# Catatan: ini "otak" agent saja. Kredensial Walrus Memory (di bawah) tetap WAJIB —
# OpenRouter tidak menggantikan Walrus Memory.

# Opsi A: Anthropic langsung
ANTHROPIC_API_KEY=sk-ant-...

# Opsi B: OpenRouter (OpenAI-compatible). Kalau ini diisi, otomatis dipakai.
OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1   # opsional, default sudah benar

# Paksa provider kalau perlu: "anthropic" | "openrouter" (default: auto-detect dari key di atas)
DENDAM_LLM_PROVIDER=

# Model id. Pilih model yang mendukung structured output (Claude/GPT-4o-class).
#  - Anthropic : claude-sonnet-4-6  (atau claude-opus-4-8 untuk kualitas maks)
#  - OpenRouter: anthropic/claude-sonnet-4  (cek slug persis di openrouter.ai/models)
DENDAM_MODEL=claude-sonnet-4-6

# --- Walrus Memory (MemWal) ---
# Get these from https://memory.walrus.xyz/dashboard
# MEMWAL_AGENT_ID is the PUBLIC KEY part of your delegate key (required by the submission form).
MEMWAL_DELEGATE_KEY=                 # delegate private key (hex) — KEEP SECRET, server-only
MEMWAL_ACCOUNT_ID=                   # your MemWalAccount id (the on-chain object holding memories)
MEMWAL_SERVER_URL=                   # relayer endpoint, e.g. https://memory.walrus.xyz
MEMWAL_AGENT_ID=                     # public key of the delegate key (put this in the submission form)

# Force a backend explicitly: "memwal" or "local". Leave empty to auto-detect.
DENDAM_MEMORY_BACKEND=
